{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit && eslint . --max-warnings=1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "seed:db": "ts-node --project tsconfig.scripts.json scripts/seed.ts",
    "mikro-orm:create": "mikro-orm migration:create",
    "docker-compose:up": "docker-compose up --build",
    "docker-compose:down": "docker-compose down",
    "docker-compose:seed": "docker-compose run --rm seed",
    "audit": "pnpm audit"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./mikro-orm.config.ts"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@mikro-orm/core": "^5.9.8",
    "@mikro-orm/migrations-mongodb": "^5.9.8",
    "@mikro-orm/mongodb": "^5.9.8",
    "@mikro-orm/reflection": "^5.9.8",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "6.5.0",
    "@primeuix/themes": "^1.2.5",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.474.0",
    "mongodb": "^5.9.2",
    "next": "16.2.2",
    "notistack": "^3.0.2",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.0",
    "react-top-loading-bar": "^3.0.2",
    "react-transition-group": "^4.4.5",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@mikro-orm/cli": "^5.9.8",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-playwright": "^2.10.1",
    "jsdom": "^27.4.0",
    "node-mocks-http": "^1.17.2",
    "rimraf": "^6.1.3",
    "text-encoding": "^0.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "ajv": ">=8.18.0"
    }
  }
}

